# --- Python virtual environment (large, rebuildable — never commit) ---
.venv/

# --- Python cache files (auto-generated) ---
__pycache__/
*.pyc

# --- Claude Code local config (not part of the project) ---
.claude/

# --- Operating-system junk files ---
Thumbs.db
.DS_Store

# --- Large data: videos & extracted frames (keep on disk, not in git) ---
data/raw_videos/*
data/frames/*

# --- Label Studio export + the split YOLO dataset (lots of images, keep local) ---
data/label_export/
data/dataset/

# --- Trained model weights (large binary files) ---
*.pt
*.onnx
models/*

# --- YOLO training output folders (auto-generated, large) ---
runs/

# --- Jupyter notebook autosave junk ---
.ipynb_checkpoints/

# ...but DO keep the empty-folder placeholders so the structure survives:
!**/.gitkeep
